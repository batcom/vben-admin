model mem_ems {
  id         Int      @id @default(autoincrement())
  event      String   @db.VarChar(30)
  email      String   @db.VarChar(100)
  code       String   @db.VarChar(10)
  times      Int      @default(0)
  ip         String?  @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
}

model mem_group {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(50)
  status     String       @default("normal") @db.VarChar(30)
  sort_order Int          @default(0)
  createdAt DateTime     @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  mem_member mem_member[]
}

model mem_member {
  id                 Int       @id @default(autoincrement())
  group_id           Int       @default(1)
  username           String?   @unique @db.VarChar(32)
  nickname           String?   @db.VarChar(50)
  password           String?   @db.VarChar(255)
  email              String?   @db.VarChar(100)
  mobile             String?   @db.VarChar(11)
  avatar             String?   @db.VarChar(255)
  level              Int       @default(0)
  gender             Int       @default(0)
  birthday           DateTime? @db.Date
  bio                String?   @db.VarChar(100)
  money              Decimal   @default(0) @db.Decimal(10, 2)
  score              Int       @default(0)
  successions        Int       @default(1)
  maxsuccessions     Int       @default(1)
  prev_time          DateTime?
  login_time         DateTime?
  loginip            String?   @db.VarChar(50)
  login_failure      Int       @default(0)
  login_failure_time DateTime?
  joinip             String?   @db.VarChar(50)
  join_time          DateTime?
  status             String    @default("normal") @db.VarChar(30)
  verification       String?   @db.VarChar(255)
  openid             String?   @unique @db.VarChar(100)
  unionid            String?   @db.VarChar(100)
  mini_openid        String?   @unique @db.VarChar(100)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  mem_group          mem_group @relation(fields: [group_id], references: [id])
}

model mem_sms {
  id         Int      @id @default(autoincrement())
  event      String   @db.VarChar(30)
  mobile     String   @db.VarChar(20)
  code       String   @db.VarChar(10)
  times      Int      @default(0)
  ip         String?  @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
}

model sys_config {
  id            Int      @id @default(autoincrement())
  group         String   @default("basic") @db.VarChar(100)
  group_sort    Int      @default(0)
  key           String   @unique @db.VarChar(100)
  label         String   @db.VarChar(200)
  value         Json?
  default_value Json?
  type          String   @default("string") @db.VarChar(50)
  sort_order    Int      @default(0)
  placeholder   String?  @db.VarChar(500)
  remark        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}
