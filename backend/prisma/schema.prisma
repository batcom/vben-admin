generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int              @id @default(autoincrement())
  username    String           @unique @db.VarChar(50)
  password    String           @db.VarChar(255)
  realName    String?          @map("real_name") @db.VarChar(50)
  email       String?          @unique @db.VarChar(100)
  phone       String?          @db.VarChar(20)
  avatar      String?          @db.VarChar(255)
  status      Int              @default(1)
  deptId      Int?             @map("dept_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  orders      Order[]
  dept        Dept?            @relation(fields: [deptId], references: [id])
  permissions UserPermission[]
  roles       UserRole[]

  @@map("sys_user")
}

model Role {
  id          Int                   @id @default(autoincrement())
  name        String                @unique @db.VarChar(50)
  code        String                @unique @db.VarChar(50)
  description String?               @db.VarChar(255)
  status      Int                   @default(1)
  sortOrder   Int                   @default(0) @map("sort_order")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  deletedAt   DateTime?             @map("deleted_at")
  dataScope   DataScope?
  apiPerms    RoleApiPermission[]
  fieldPerms  RoleFieldPermission[]
  menus       RoleMenu[]
  permissions RolePermission[]
  users       UserRole[]

  @@map("sys_role")
}

model UserRole {
  userId Int  @map("user_id")
  roleId Int  @map("role_id")
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("sys_user_role")
}

model Menu {
  id          Int          @id @default(autoincrement())
  parentId    Int?         @map("parent_id")
  name        String       @db.VarChar(100)
  type        Int          @default(0)
  path        String?      @db.VarChar(200)
  component   String?      @db.VarChar(200)
  icon        String?      @db.VarChar(100)
  sortOrder   Int          @default(0) @map("sort_order")
  perms       String?      @db.VarChar(100)
  status      Int          @default(1)
  keepAlive   Int?         @default(1) @map("keep_alive")
  show        Int          @default(1)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")
  redirect    String?      @db.VarChar(200)
  routeName   String?      @map("route_name") @db.VarChar(100)
  parent      Menu?        @relation("MenuTree", fields: [parentId], references: [id])
  children    Menu[]       @relation("MenuTree")
  permissions Permission[]
  roles       RoleMenu[]

  @@map("sys_menu")
}

model RoleMenu {
  roleId Int  @map("role_id")
  menuId Int  @map("menu_id")
  menu   Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@map("sys_role_menu")
}

model Permission {
  id        Int              @id @default(autoincrement())
  name      String           @db.VarChar(100)
  code      String           @unique @db.VarChar(100)
  menuId    Int?             @map("menu_id")
  createdAt DateTime         @default(now()) @map("created_at")
  menu      Menu?            @relation(fields: [menuId], references: [id])
  roles     RolePermission[]
  users     UserPermission[]

  @@map("sys_permission")
}

model UserPermission {
  userId       Int        @map("user_id")
  permissionId Int        @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("sys_user_permission")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("sys_role_permission")
}

model ApiPermission {
  id        Int                 @id @default(autoincrement())
  name      String              @db.VarChar(100)
  method    String              @db.VarChar(10)
  path      String              @db.VarChar(200)
  createdAt DateTime            @default(now()) @map("created_at")
  roles     RoleApiPermission[]

  @@map("sys_api_permission")
}

model RoleApiPermission {
  roleId          Int           @map("role_id")
  apiPermissionId Int           @map("api_permission_id")
  apiPermission   ApiPermission @relation(fields: [apiPermissionId], references: [id], onDelete: Cascade)
  role            Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, apiPermissionId])
  @@map("sys_role_api_permission")
}

model FieldPermission {
  id        Int                   @id @default(autoincrement())
  tableName String                @map("table_name") @db.VarChar(100)
  fieldName String                @map("field_name") @db.VarChar(100)
  createdAt DateTime              @default(now()) @map("created_at")
  roles     RoleFieldPermission[]

  @@unique([tableName, fieldName])
  @@map("sys_field_permission")
}

model RoleFieldPermission {
  roleId            Int             @map("role_id")
  fieldPermissionId Int             @map("field_permission_id")
  readable          Int             @default(1)
  fieldPermission   FieldPermission @relation(fields: [fieldPermissionId], references: [id], onDelete: Cascade)
  role              Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, fieldPermissionId])
  @@map("sys_role_field_permission")
}

model DataScope {
  id            Int      @id @default(autoincrement())
  roleId        Int      @unique @map("role_id")
  scopeType     String   @map("scope_type") @db.Char(1)
  customDeptIds String?  @map("custom_dept_ids")
  createdAt     DateTime @default(now()) @map("created_at")
  role          Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("sys_data_scope")
}

model Dept {
  id        Int       @id @default(autoincrement())
  parentId  Int?      @map("parent_id")
  name      String    @db.VarChar(100)
  sortOrder Int       @default(0) @map("sort_order")
  status    Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  parent    Dept?     @relation("DeptTree", fields: [parentId], references: [id])
  children  Dept[]    @relation("DeptTree")
  users     User[]

  @@map("sys_dept")
}

model Order {
  id          Int       @id @default(autoincrement())
  orderNo     String    @unique @map("order_no") @db.VarChar(50)
  userId      Int?      @map("user_id")
  totalAmount Decimal   @map("total_amount") @db.Decimal(10, 2)
  status      String    @default("pending") @db.VarChar(20)
  remark      String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  user        User?     @relation(fields: [userId], references: [id])

  @@map("sys_order")
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(200)
  content     String
  summary     String?   @db.VarChar(500)
  coverUrl    String?   @map("cover_url") @db.VarChar(500)
  tags        String?   @db.VarChar(200)
  status      String    @default("draft")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("cms_article")
}

model biz_aigc_task {
  id              Int       @id @default(autoincrement())
  member_id       Int?
  type            String    @db.VarChar(30)
  prompt          String?
  negative_prompt String?
  image_url       String?   @db.VarChar(500)
  video_url       String?   @db.VarChar(500)
  status          String    @default("pending") @db.VarChar(20)
  progress        Int       @default(0)
  config          Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
}

model biz_app_tool {
