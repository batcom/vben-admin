generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth & Users ====================

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique @db.VarChar(50)
  password  String    @db.VarChar(255)
  realName  String?   @map("real_name") @db.VarChar(50)
  email     String?   @unique @db.VarChar(100)
  phone     String?   @db.VarChar(20)
  avatar    String?   @db.VarChar(255)
  status    Int       @default(1) // 1=active 0=disabled
  deptId    Int?      @map("dept_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  dept        Dept?           @relation(fields: [deptId], references: [id])
  roles       UserRole[]
  permissions UserPermission[]
  orders      Order[]

  @@map("sys_user")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  code        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  status      Int      @default(1)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users           UserRole[]
  menus           RoleMenu[]
  permissions     RolePermission[]
  apiPerms        RoleApiPermission[]
  fieldPerms      RoleFieldPermission[]
  dataScope       DataScope?

  @@map("sys_role")
}

model UserRole {
  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("sys_user_role")
}

// ==================== Menu & Permission ====================

model Menu {
  id        Int      @id @default(autoincrement())
  parentId  Int?     @map("parent_id")
  name      String   @db.VarChar(100)
  routeName String?  @map("route_name") @db.VarChar(100)
  type      Int      @default(0) // 0=directory 1=menu 2=button
  path      String?  @db.VarChar(200)
  component String?  @db.VarChar(200)
  redirect  String?  @db.VarChar(200)
  icon      String?  @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  perms     String?  @db.VarChar(100) // button permission code
  status    Int      @default(1)
  keepAlive Int?     @default(1) @map("keep_alive")
  show      Int      @default(1) // 0=hide in sidebar
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  parent      Menu?         @relation("MenuTree", fields: [parentId], references: [id])
  children    Menu[]        @relation("MenuTree")
  roles       RoleMenu[]
  permissions Permission[]

  @@map("sys_menu")
}

model RoleMenu {
  roleId Int @map("role_id")
  menuId Int @map("menu_id")

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@map("sys_role_menu")
}

// Permission codes (button-level)
model Permission {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  code      String   @unique @db.VarChar(100)
  menuId    Int?     @map("menu_id")
  createdAt DateTime @default(now()) @map("created_at")

  menu    Menu?             @relation(fields: [menuId], references: [id])
  roles   RolePermission[]
  users   UserPermission[]

  @@map("sys_permission")
}

model UserPermission {
  userId       Int @map("user_id")
  permissionId Int @map("permission_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("sys_user_permission")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("sys_role_permission")
}

// API-level permissions
model ApiPermission {
  id        Int            @id @default(autoincrement())
  name      String         @db.VarChar(100)
  method    String         @db.VarChar(10) // GET, POST, PUT, DELETE
  path      String         @db.VarChar(200)
  createdAt DateTime       @default(now()) @map("created_at")

  roles RoleApiPermission[]

  @@map("sys_api_permission")
}

model RoleApiPermission {
  roleId          Int @map("role_id")
  apiPermissionId Int @map("api_permission_id")

  role          Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  apiPermission ApiPermission @relation(fields: [apiPermissionId], references: [id], onDelete: Cascade)

  @@id([roleId, apiPermissionId])
  @@map("sys_role_api_permission")
}

// Field-level permissions
model FieldPermission {
  id        Int                  @id @default(autoincrement())
  tableName String               @map("table_name") @db.VarChar(100)
  fieldName String               @map("field_name") @db.VarChar(100)
  createdAt DateTime             @default(now()) @map("created_at")

  roles RoleFieldPermission[]

  @@unique([tableName, fieldName])
  @@map("sys_field_permission")
}

model RoleFieldPermission {
  roleId            Int @map("role_id")
  fieldPermissionId Int @map("field_permission_id")
  readable          Int @default(1) // 1=readable 0=hidden

  role            Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  fieldPermission FieldPermission @relation(fields: [fieldPermissionId], references: [id], onDelete: Cascade)

  @@id([roleId, fieldPermissionId])
  @@map("sys_role_field_permission")
}

// Data scope
model DataScope {
  id            Int    @id @default(autoincrement())
  roleId        Int    @unique @map("role_id")
  scopeType     String @map("scope_type") @db.Char(1) // 1=self 2=dept 3=dept_sub 4=all 5=custom
  customDeptIds String? @map("custom_dept_ids") // JSON array of dept IDs when scopeType=5
  createdAt     DateTime @default(now()) @map("created_at")

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("sys_data_scope")
}

// ==================== Dept ====================

model Dept {
  id        Int       @id @default(autoincrement())
  parentId  Int?      @map("parent_id")
  name      String    @db.VarChar(100)
  sortOrder Int       @default(0) @map("sort_order")
  status    Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  parent   Dept?  @relation("DeptTree", fields: [parentId], references: [id])
  children Dept[] @relation("DeptTree")
  users    User[]

  @@map("sys_dept")
}

// ==================== Orders ====================

model Order {
  id          Int       @id @default(autoincrement())
  orderNo     String    @unique @map("order_no") @db.VarChar(50)
  userId      Int?      @map("user_id")
  totalAmount Decimal   @map("total_amount") @db.Decimal(10, 2)
  status      String    @default("pending") @db.VarChar(20) // pending, processing, completed, cancelled
  remark      String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("sys_order")
}
